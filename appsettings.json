{
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=skybazaar.db"
  },
  "Bazaar": {
    "FetchIntervalSeconds": 300,
    "RetentionDays": 30,
    "MaxRetries": 3,
    "RetryDelaySeconds": 10
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}

{
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=skybazaar.db"
  },
  "Bazaar": {
    "MinDelayAfterSnapshotSeconds": 9.5,
    "RetentionDays": 30,
    "MaxRetries": 3,
    "RetryDelaySeconds": 10,
    "PollWaitMs": 500,
    "MaxPollRetries": 100,
    "OrdersToStore": 3
  },
  "Hypixel": {
    "ApiKey": ""
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
